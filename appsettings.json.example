{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AWS": {
    "Region": "us-east-2",
    "BucketName": "your-bucket-name",
    "AccessKey": "USE_ENVIRONMENT_VARIABLE_AWS_ACCESS_KEY_ID",
    "SecretKey": "USE_ENVIRONMENT_VARIABLE_AWS_SECRET_ACCESS_KEY"
  },
  "LocalData": {
    "Enabled": false,
    "DefaultFile": "",
    "PrefixFiles": {}
  },
  "AllowedOrigins": [
    "https://your-production-domain.com",
    "https://your-staging-domain.com"
  ],
  "Security": {
    "JwtSecret": "USE_ENVIRONMENT_VARIABLE_JWT_SECRET",
    "JwtIssuer": "aspec-capture-api",
    "JwtAudience": "aspec-capture-client",
    "JwtExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 7
  },
  "RateLimit": {
    "GeneralRequestsPerMinute": 60,
    "LoginAttemptsPerFifteenMinutes": 5,
    "CaptureRequestsPerMinute": 30
  }
}
