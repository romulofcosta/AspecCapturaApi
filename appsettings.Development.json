{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AWS": {
    "Region": "us-east-2",
    "BucketName": "aspec-captura"
  },
  "Security": {
    "JwtIssuer": "aspec-capture-api",
    "JwtAudience": "aspec-capture-client",
    "JwtExpirationMinutes": 480
  },
  "AllowedOrigins": "http://localhost:5000,https://localhost:5001,https://*.pages.dev",
  "Features": {
    "EnableDetailedErrors": true,
    "EnableSwagger": true
  }
}
