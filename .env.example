# ============================================================================
# ASPEC CAPTURA API - VARIÁVEIS DE AMBIENTE
# ============================================================================
# INSTRUÇÕES:
# 1. Copie este arquivo para .env: cp .env.example .env
# 2. Preencha com valores reais
# 3. NUNCA commite o arquivo .env no Git!
# ============================================================================

# Ambiente
ASPNETCORE_ENVIRONMENT=Development

# ============================================================================
# AWS CREDENTIALS
# ============================================================================
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_REGION=us-east-2
AWS_BUCKET_NAME=aspec-capture

# ============================================================================
# JWT AUTHENTICATION
# ============================================================================
JWT_SECRET=mvp-test-secret-change-in-production
JWT_ISSUER=aspec-capture-api
JWT_AUDIENCE=aspec-capture-client
JWT_EXPIRATION_MINUTES=480

# ============================================================================
# CORS
# ============================================================================
ALLOWED_ORIGINS=http://localhost:5000,https://localhost:5001,https://*.pages.dev
