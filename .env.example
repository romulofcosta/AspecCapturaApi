# ============================================================================
# ASPEC CAPTURA API — SECRETS LOCAIS (EXEMPLO)
# ============================================================================
# Copie este arquivo para .env e preencha com suas credenciais reais.
# Configurações não-sensíveis ficam em appsettings.Development.json
# ============================================================================

# ─── AWS CREDENTIALS ─────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=AKIA_SEU_ACCESS_KEY_AQUI
AWS_SECRET_ACCESS_KEY=seu_secret_key_aqui

# ─── JWT SECRET ──────────────────────────────────────────────────────────────
# Gere com: openssl rand -base64 64
JWT_SECRET=gere_um_secret_forte_com_openssl_rand_base64_64
