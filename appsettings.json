{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.AspNetCore.HttpLogging": "Information"
    }
  },
  "AllowedHosts": "*",
  "AWS": {
    "Region": "AWS__Region",
    "BucketName": "AWS__BucketName",
    "AccessKey": "AWS__AccessKey",
    "SecretKey": "AWS__SecretKey"
  },
  "Security": {
    "JwtSecret": "USE_ENVIRONMENT_VARIABLE_JWT_SECRET",
    "JwtIssuer": "aspec-capture-api",
    "JwtAudience": "aspec-capture-client",
    "JwtExpirationMinutes": 480,
    "RefreshTokenExpirationDays": 7
  },
  "RateLimit": {
    "Enabled": false,
    "GeneralRequestsPerMinute": 60,
    "LoginAttemptsPerFifteenMinutes": 5,
    "CaptureRequestsPerMinute": 30
  },
  "Features": {
    "EnableSwagger": true,
    "EnableDetailedErrors": true,
    "EnableRequestLogging": true
  }
}
